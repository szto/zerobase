# ── 복사해서 .env 로 사용. Coolify 에서는 UI 의 Environment Variables 에 입력 ──

# 필수: 서비스 식별
SERVICE_NAME=myservice
SERVICE_DOMAIN=myservice.example.com

# 필수: Django 시크릿 (생성: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=change-me

# 선택: 디버그 (프로덕션에서는 반드시 false)
DEBUG=false
LOG_LEVEL=INFO

# uvicorn 워커 수 (SQLite 특성상 2 를 표준 기본값으로)
WEB_CONCURRENCY=2

# ── Litestream: SQLite → Cloudflare R2 실시간 복제 ──
# LITESTREAM_BUCKET 을 비워두면 복제 없이 기동 (로컬 개발). 프로덕션에서는 반드시 설정.
LITESTREAM_BUCKET=
# 버킷 안에서 서비스별 경로 (서비스 이름과 동일하게)
LITESTREAM_PATH=myservice
# R2 엔드포인트: https://<account-id>.r2.cloudflarestorage.com
LITESTREAM_ENDPOINT=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# ── 프록시 신뢰 (Cloudflare Tunnel + Traefik/Caddy 뒤에 있을 때) ──
DJUST_TRUSTED_PROXIES=

# REDIS_URL 은 compose 가 자동 주입 (redis://redis:6379/0) — 직접 설정 불필요
